#!/bin/bash
#PBS -l nodes=1:ppn=1,vmem=16gb,walltime=02:00:00
#PBS -N bl.bem

#SBATCH --ntasks-per-node=1
#SBATCH --mem=16G
#SBATCH --time=02:00:00

set -e
set -x

module load proxy

if [ -n "$FREESURFER_LICENSE" ]; then
    echo $FREESURFER_LICENSE > license.txt
elif [ -n "$FS_LICENSE" ] && [ -f "$FS_LICENSE" ]; then
    cp "$FS_LICENSE" license.txt
else
    echo "Please set FREESURFER_LICENSE or FS_LICENSE in resource environment" && exit 1
fi

singularity exec \
  --pwd `pwd` \
  --env FREESURFER_HOME=/usr/local/freesurfer \
  -B `pwd`/license.txt:/usr/local/freesurfer/license.txt \
  docker://brainlife/mne-freesurfer:7.3.2-1.2.1 \
  python3 main.py
